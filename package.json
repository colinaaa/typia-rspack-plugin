{
  "name": "typia-rspack-plugin",
  "version": "2.2.2",
  "description": "A plugin for Rspack to use Typia.",
  "keywords": [
    "rspack",
    "plugin",
    "typia"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/colinaaa/typia-rspack-plugin.git"
  },
  "license": "MIT",
  "author": {
    "name": "Qingyu Wang",
    "email": "colinwang.0616@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
